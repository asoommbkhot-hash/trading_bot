import ccxt
import pandas as pd
import numpy as np
import time
import requests

BOT_TOKEN = "8649487835:AAGsfqRi3apYJy6NPCroQglrNtlWvvXtj40"
CHAT_ID = "8135113807"

def send(msg):
    try:
        url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
        requests.post(url, data={"chat_id": CHAT_ID, "text": msg}, timeout=10)
    except:
        pass

exchange = ccxt.binance({'enableRateLimit': True, 'timeout': 30000})

symbols = ["BTC/USDT","ETH/USDT","SOL/USDT"]

positions = {}

send("🚀 Level 3 Started")

def get_data(symbol):
    df = pd.DataFrame(exchange.fetch_ohlcv(symbol, '15m', limit=120),
                      columns=['t','o','h','l','c','v'])
    return df

def indicators(df):
    df['ema50'] = df['c'].ewm(span=50).mean()
    df['ema200'] = df['c'].ewm(span=200).mean()

    delta = df['c'].diff()
    gain = delta.clip(lower=0).rolling(14).mean()
    loss = (-delta.clip(upper=0)).rolling(14).mean()
    rs = gain / loss.replace(0, np.nan)
    df['rsi'] = 100 - (100 / (1 + rs))

    df['tr'] = np.maximum(df['h'] - df['l'],
                 np.maximum(abs(df['h'] - df['c'].shift()),
                            abs(df['l'] - df['c'].shift())))
    df['atr'] = df['tr'].rolling(14).mean()

    return df

while True:

    for s in symbols:

        try:
            df = indicators(get_data(s))
            last = df.iloc[-1]

            price = last['c']

            trend = last['ema50'] > last['ema200']
            rsi_ok = 40 < last['rsi'] < 65

            # ===== ENTRY ===== #
            if s not in positions:

                if trend and rsi_ok:

                    sl = price - last['atr'] * 1.5
                    tp = price + last['atr'] * 3

                    positions[s] = {"entry": price, "sl": sl, "tp": tp}

                    msg = f"""📈 ENTRY
{s}
Entry: {price}
SL: {sl}
TP: {tp}"""

                    send(msg)
                    print(msg)

            # ===== EXIT ===== #
            else:

                pos = positions[s]

                if price <= pos['sl'] or price >= pos['tp']:

                    result = "TP" if price >= pos['tp'] else "SL"

                    msg = f"""📉 EXIT
{s}
Price: {price}
Result: {result}"""

                    send(msg)
                    print(msg)

                    del positions[s]

        except Exception as e:
            print("ERROR:", e)

    print("🟢 Running OK")
    time.sleep(60)
